script = ExtResource("1_script")

[node name="Column" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 8

[node name="TitleLabel" type="Label" parent="Column"]
layout_mode = 2
theme_type_variation = &"HudTurnHelper"
text = "Historique"

[node name="HistoryScroll" type="ScrollContainer" parent="Column"]

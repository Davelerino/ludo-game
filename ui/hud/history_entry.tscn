[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/hud/history_entry.gd" id="1_script"]

[node name="HistoryEntry" type="PanelContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_type_variation = &"HistoryEntryRow"
script = ExtResource("1_script")

[node name="Column" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 2

[node name="EntryHeader" type="Label" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"HistoryEntryHeader"
text = "Joueur — dés"
autowrap_mode = 2

[node name="EntryDetail" type="Label" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"HistoryEntryDetail"
text = "Détail du coup"
autowrap_mode = 3
